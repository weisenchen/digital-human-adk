# ── Required ───────────────────────────────────────────
# Gemini API key for the AI brain (gemini-2.5-flash)
# Get one free: https://aistudio.google.com
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Voice (optional) ───────────────────────────────────
# Leave these as-is if you only want text chat.
# Voice needs additional setup (see README).

# TTS provider: edge (free, no key), google, openai
TTS_PROVIDER=edge
# STT provider: whisper (needs OPENAI_API_KEY), google
STT_PROVIDER=whisper
# OPENAI_API_KEY=sk-...

# ── Server ─────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
