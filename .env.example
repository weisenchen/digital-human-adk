# ── Required ───────────────────────────────────────────
# Gemini API key for the AI brain (gemini-2.5-flash)
# Get one free: https://aistudio.google.com
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Voice (optional) ───────────────────────────────────
# Leave as-is if you only want text chat.
# TTS provider: edge (free, no key), google, openai
TTS_PROVIDER=edge

# TTS synthesis timeout (seconds). Prevents hanging requests.
TTS_TIMEOUT=30

# ── Server ─────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
